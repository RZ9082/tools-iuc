<tool id="mgnify_pipelines_toolkit_rev_comp_se_primers" name="Generate Reverse Complements of Primers" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Create reverse-complement sequences for primer FASTA entries</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="creators"/>
    <expand macro="requirements"/>
    <command detect_errors="aggressive"><![CDATA[
        #set input_base = str($input.name).rsplit('.',1)[0]
        rev_comp_se_primers -i '$input' -s '$input_base' -o ./ &&
        mv '$input_base'_rev_comp_se_primers.fasta '$output'
    ]]></command>
    <inputs>
        <param name="input" type="data" label="Primer sequences" format="fasta"/>
    </inputs>    
    <outputs>
        <data name="output" label="${tool.name} on ${on_string}: Reverse-complemented primers" format="fasta"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input" value="f_and_r_primers.fasta" ftype="fasta" />
            <output name="output" file="sample_rev_comp_se_primers.fasta" ftype="fasta"/>
        </test>
    </tests>
    <help>
<![CDATA[ 
**Generate Reverse Complements of Primers**
-------------------------------------------

This tool generates **reverse-complement sequences** for primer entries in a FASTA file.

-----

@LICENSE@
]]>
    </help>
    <expand macro="citations" />
</tool>
