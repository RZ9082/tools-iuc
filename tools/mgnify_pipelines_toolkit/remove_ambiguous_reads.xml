<tool id="mgnify_pipelines_toolkit_remove_ambiguous_reads" name="Remove ambiguous reads" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Filter sequencing reads containing ambiguous nucleotides, and reads shorter than 100 bp</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="creators"/>
    <expand macro="requirements"/>
    <command detect_errors="aggressive"><![CDATA[
        #set input_base = str($input.name).rsplit('.',1)[0]
        #if $input_type.type == 'single'
            remove_ambiguous_reads
                    -f '$input_type.input'
                    -s '$input_base' &&
            mv '$input_base'_noambig.fastq.gz '$output_single'
        #else
            remove_ambiguous_reads
                    -f '$input_type.input.forward'
                    -r '$input_type.input.reverse'
                    -s '$input_base' &&
            mv '$input_base'_noambig_1.fastq.gz '$output_paired.forward' &&
            mv '$input_base'_noambig_2.fastq.gz '$output_paired.reverse'
        #end if
    ]]></command>
    <inputs>
        <conditional name="input_type">
            <param name="type" type="select" label="Single-end or Paired-end reads?">
                <option value="single">Single-end</option>
                <option value="paired_collection">Paired-end Collection</option>
            </param>
            <when value="single">
                <param name="input" format="fastqsanger" type="data" label="FASTQ/A file" help="Should be of datatype &quot;fastq.gz&quot; or &quot;fasta&quot;" />
            </when>
            <when value="paired_collection">
                <param name="input" format="fastqsanger" type="data_collection" collection_type="paired" label="Paired Collection" help="Should be of datatype &quot;fastq.gz&quot; or &quot;fasta&quot;" />
            </when>
        </conditional>
    </inputs>    
    <outputs>
        <data name="output_single" label="${tool.name} on ${on_string}: Filtered reads" format="fastqsanger.gz">
            <filter>input_type['type'] == "single"</filter>
        </data>
        <collection name="output_paired" type="paired" label="${tool.name} on ${on_string}: Filtered paired-end reads" format="fastqsanger.gz">
            <filter>input_type['type'] == "paired_collection"</filter>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <conditional name="input_type">
                <param name="type" value="single"/>
                <param name="input" value="test_1_withNs.fastq"/>
            </conditional>
            <output name="output_single" file="sample_noambig_1.fastq.gz" ftype="fastqsanger.gz"/>
        </test>
        <test expect_num_outputs="3">
            <conditional name="input_type">
                <param name="type" value="paired_collection"/>

                <param name="input">
                    <collection type="paired">
                        <element name="forward" value="test_1_withNs.fastq" ftype="fastqsanger.gz"/>
                        <element name="reverse" value="test_2_withNs.fastq" ftype="fastqsanger.gz"/>
                    </collection>
                </param>
            </conditional>

            <output_collection name="output_paired" type="paired">
                <element name="forward" file="sample_noambig_1.fastq.gz" ftype="fastqsanger.gz"/>
                <element name="reverse" file="sample_noambig_2.fastq.gz" ftype="fastqsanger.gz"/>
            </output_collection>
        </test>
    </tests>
    <help>
<![CDATA[ 
**Remove Reads with Ambiguous Bases**
-------------------------------------
This tool filters sequencing reads that contain **ambiguous nucleotide characters**, and reads **shorter than 100 bp**.

-----

@LICENSE@
]]>
    </help>
    <expand macro="citations" />
</tool>
